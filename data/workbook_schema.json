{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Workbook Collection",
  "description": "Collection of week documents for workbook generation. Each document can be a normal week, special event, or visit week.",
  "type": "array",
  "items": {
    "oneOf": [
      { "$ref": "#/definitions/normalWeek" },
      { "$ref": "#/definitions/specialEventWeek" },
      { "$ref": "#/definitions/visitWeek" }
    ]
  },
  "definitions": {
    "normalWeek": {
      "type": "object",
      "title": "Normal Meeting Week",
      "description": "A regular week with full meeting agenda",
      "additionalProperties": false,
      "required": [
        "week",
        "bible_reading",
        "songs",
        "prayers",
        "chairman",
        "initial_comments",
        "treasures",
        "ministry",
        "christian_life",
        "final_comments"
      ],
      "properties": {
        "week": {
          "type": "string",
          "description": "Week date range (e.g., '25-31 de maio')",
          "minLength": 1
        },
        "bible_reading": {
          "type": "string",
          "description": "Bible reading reference (e.g., 'ISAÍAS 65-66')",
          "minLength": 1
        },
        "songs": {
          "type": "array",
          "description": "List of songs to be performed (must be exactly 3)",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1,
            "description": "Song identifier (e.g., 'Cântico 24')"
          }
        },
        "prayers": {
          "type": "array",
          "description": "List of prayers to be performed (must be exactly 2)",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "minLength": 1,
            "description": "Prayer identifier or description"
          }
        },
        "chairman": {
          "type": "string",
          "description": "Name of the chairman",
          "minLength": 1
        },
        "initial_comments": {
          "type": "object",
          "description": "Initial comments section",
          "additionalProperties": false,
          "required": ["who", "duration"],
          "properties": {
            "who": {
              "type": "string",
              "description": "Person responsible for initial comments",
              "minLength": 1
            },
            "duration": {
              "type": "string",
              "description": "Duration of the segment (e.g., '1 min')",
              "pattern": "^\\d+\\s*min$"
            }
          }
        },
        "treasures": {
          "type": "object",
          "description": "Spiritual treasures section with multiple subsections",
          "additionalProperties": false,
          "required": ["speech", "jewels", "bible_reading"],
          "properties": {
            "speech": {
              "$ref": "#/definitions/segment"
            },
            "jewels": {
              "type": "object",
              "description": "Spiritual jewels segment",
              "additionalProperties": false,
              "required": ["who", "duration"],
              "properties": {
                "who": {
                  "type": "string",
                  "minLength": 1
                },
                "duration": {
                  "type": "string",
                  "pattern": "^\\d+\\s*min$"
                }
              }
            },
            "bible_reading": {
              "type": "object",
              "description": "Bible reading segment",
              "additionalProperties": false,
              "required": ["who", "duration"],
              "properties": {
                "who": {
                  "type": "string",
                  "minLength": 1
                },
                "duration": {
                  "type": "string",
                  "pattern": "^\\d+\\s*min$"
                }
              }
            }
          }
        },
        "ministry": {
          "type": "array",
          "description": "Ministry demonstrations and talks",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/multiPersonSegment"
          }
        },
        "christian_life": {
          "type": "object",
          "description": "Christian life section with discussion parts and congregation study",
          "additionalProperties": false,
          "required": ["parts", "congregation_study"],
          "properties": {
            "parts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/definitions/segment"
              }
            },
            "congregation_study": {
              "type": "object",
              "description": "Congregation Bible study",
              "additionalProperties": false,
              "required": ["title", "duration", "conductor", "reader"],
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "duration": {
                  "type": "string",
                  "pattern": "^\\d+\\s*min$"
                },
                "conductor": {
                  "type": "string",
                  "minLength": 1
                },
                "reader": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "final_comments": {
          "type": "object",
          "description": "Final comments section",
          "additionalProperties": false,
          "required": ["who", "duration"],
          "properties": {
            "who": {
              "type": "string",
              "minLength": 1
            },
            "duration": {
              "type": "string",
              "pattern": "^\\d+\\s*min$"
            }
          }
        }
      }
    },
    "specialEventWeek": {
      "type": "object",
      "title": "Special Event Week",
      "description": "A week with no regular meeting (e.g., convention, assembly, special event)",
      "additionalProperties": false,
      "required": ["week", "bible_reading", "no_meeting", "reason"],
      "properties": {
        "week": {
          "type": "string",
          "description": "Week date range",
          "minLength": 1
        },
        "bible_reading": {
          "type": "string",
          "description": "Bible reading reference",
          "minLength": 1
        },
        "no_meeting": {
          "type": "boolean",
          "description": "Flag indicating this is a special event week with no meeting",
          "enum": [true]
        },
        "reason": {
          "type": "string",
          "description": "Reason for no meeting (e.g., 'Convenção de Circuito', 'Assembleia Regional')",
          "minLength": 1
        }
      }
    },
    "visitWeek": {
      "type": "object",
      "title": "Visit Week",
      "description": "A week when an important visitor replaces the congregation study with their speech",
      "additionalProperties": false,
      "required": [
        "week",
        "bible_reading",
        "songs",
        "prayers",
        "chairman",
        "initial_comments",
        "treasures",
        "ministry",
        "christian_life",
        "final_comments",
        "visit"
      ],
      "properties": {
        "week": {
          "type": "string",
          "minLength": 1
        },
        "bible_reading": {
          "type": "string",
          "minLength": 1
        },
        "songs": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prayers": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "chairman": {
          "type": "string",
          "minLength": 1
        },
        "initial_comments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["who", "duration"],
          "properties": {
            "who": {
              "type": "string",
              "minLength": 1
            },
            "duration": {
              "type": "string",
              "pattern": "^\\d+\\s*min$"
            }
          }
        },
        "treasures": {
          "type": "object",
          "additionalProperties": false,
          "required": ["speech", "jewels", "bible_reading"],
          "properties": {
            "speech": {
              "$ref": "#/definitions/segment"
            },
            "jewels": {
              "type": "object",
              "additionalProperties": false,
              "required": ["who", "duration"],
              "properties": {
                "who": {
                  "type": "string",
                  "minLength": 1
                },
                "duration": {
                  "type": "string",
                  "pattern": "^\\d+\\s*min$"
                }
              }
            },
            "bible_reading": {
              "type": "object",
              "additionalProperties": false,
              "required": ["who", "duration"],
              "properties": {
                "who": {
                  "type": "string",
                  "minLength": 1
                },
                "duration": {
                  "type": "string",
                  "pattern": "^\\d+\\s*min$"
                }
              }
            }
          }
        },
        "ministry": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/multiPersonSegment"
          }
        },
        "christian_life": {
          "type": "object",
          "additionalProperties": false,
          "required": ["parts", "visit"],
          "properties": {
            "parts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/definitions/segment"
              }
            },
            "visit": {
              "type": "object",
              "description": "Visiting speaker who addresses the congregation",
              "additionalProperties": false,
              "required": ["name", "title", "duration"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Name of the visiting speaker",
                  "minLength": 1
                },
                "title": {
                  "type": "string",
                  "description": "Speech title",
                  "minLength": 1
                },
                "duration": {
                  "type": "string",
                  "description": "Duration of the visit speech",
                  "pattern": "^\\d+\\s*min$"
                }
              }
            }
          }
        },
        "final_comments": {
          "type": "object",
          "additionalProperties": false,
          "required": ["who", "duration"],
          "properties": {
            "who": {
              "type": "string",
              "minLength": 1
            },
            "duration": {
              "type": "string",
              "pattern": "^\\d+\\s*min$"
            }
          }
        }
      }
    },
    "segment": {
      "type": "object",
      "description": "A segment with speaker, title, and duration",
      "additionalProperties": false,
      "required": ["who", "title", "duration"],
      "properties": {
        "who": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "duration": {
          "type": "string",
          "pattern": "^\\d+\\s*min$"
        }
      }
    },
    "multiPersonSegment": {
      "type": "object",
      "description": "A segment with title, duration, and multiple participants",
      "additionalProperties": false,
      "required": ["title", "duration", "who"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "duration": {
          "type": "string",
          "pattern": "^\\d+\\s*min$"
        },
        "who": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
